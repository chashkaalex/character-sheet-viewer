{
  "compilerOptions": {
    "target": "ES2019",
    "module": "CommonJS",
    "lib": ["es2019", "dom"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": false,
    "noImplicitAny": false,
    "rootDir": "../src/server",
    "outDir": "../dist/server_out",
    "types": ["google-apps-script"],
    "paths": {
      "@server/*": ["../src/server/*"]
    }
  },
  "include": ["../src/server/**/*.ts"]
}
